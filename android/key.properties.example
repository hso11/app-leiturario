# Copie este arquivo para android/key.properties e preencha com os dados da
# sua keystore de RELEASE. NUNCA versione o key.properties nem o .jks.
#
# Gerar a keystore (uma vez):
#   keytool -genkey -v -keystore leiturario-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias leiturario
#
# storeFile pode ser caminho absoluto ou relativo à pasta android/app.

storeFile=../leiturario-release.jks
storePassword=SUA_SENHA_DA_KEYSTORE
keyAlias=leiturario
keyPassword=SUA_SENHA_DA_CHAVE
